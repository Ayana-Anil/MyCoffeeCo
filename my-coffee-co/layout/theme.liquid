<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {%- comment -%} Google Fonts: Inter + Montserrat {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Montserrat:wght@700;800&display=swap" rel="stylesheet">

    {%- comment -%} Material Symbols Outlined icon font {%- endcomment -%}
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet">

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # MyCoffeeCo theme CSS %}
    {{ 'mycoffeeco.css' | asset_url | stylesheet_tag }}

    {% # Tailwind CSS CDN (matches code.html config) %}
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        try {
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        "colors": {
                            "on-tertiary-container": "#ffa899",
                            "on-tertiary": "#ffffff",
                            "primary-container": "#0a06ff",
                            "on-error": "#ffffff",
                            "surface-dim": "#dadada",
                            "on-surface-variant": "#454558",
                            "tertiary": "#730400",
                            "error": "#ba1a1a",
                            "primary-fixed": "#e0e0ff",
                            "surface-container-high": "#e8e8e8",
                            "primary-fixed-dim": "#bfc2ff",
                            "tertiary-fixed-dim": "#ffb4a7",
                            "tertiary-container": "#9e0700",
                            "secondary": "#5e5e5e",
                            "secondary-container": "#e2e2e2",
                            "outline-variant": "#c5c4db",
                            "on-primary-fixed": "#01006e",
                            "surface-bright": "#f9f9f9",
                            "surface-tint": "#353cff",
                            "error-container": "#ffdad6",
                            "surface-variant": "#e2e2e2",
                            "outline": "#757589",
                            "on-error-container": "#93000a",
                            "on-tertiary-fixed-variant": "#920600",
                            "on-surface": "#1a1c1c",
                            "secondary-fixed": "#e2e2e2",
                            "secondary-fixed-dim": "#c6c6c6",
                            "on-secondary": "#ffffff",
                            "tertiary-fixed": "#ffdad4",
                            "surface-container-low": "#f3f3f4",
                            "surface-container-lowest": "#ffffff",
                            "surface-container": "#eeeeee",
                            "on-primary": "#ffffff",
                            "on-primary-fixed-variant": "#0500ef",
                            "on-background": "#1a1c1c",
                            "on-secondary-container": "#646464",
                            "inverse-primary": "#bfc2ff",
                            "on-primary-container": "#b5b9ff",
                            "on-secondary-fixed": "#1b1b1b",
                            "inverse-on-surface": "#f0f1f1",
                            "surface-container-highest": "#e2e2e2",
                            "inverse-surface": "#2f3131",
                            "on-tertiary-fixed": "#400100",
                            "on-secondary-fixed-variant": "#474747",
                            "surface": "#f9f9f9",
                            "background": "#f9f9f9",
                            "primary": "#0300be"
                        },
                        "borderRadius": {
                            "DEFAULT": "0px",
                            "lg": "0px",
                            "xl": "0px",
                            "full": "9999px"
                        },
                        "spacing": {
                            "margin-mobile": "20px",
                            "stack-lg": "80px",
                            "stack-sm": "16px",
                            "container-max": "1440px",
                            "gutter": "24px",
                            "base": "8px",
                            "margin-desktop": "64px",
                            "stack-md": "40px"
                        },
                        "fontFamily": {
                            "label-sm": ["Inter"],
                            "headline-lg": ["Montserrat"],
                            "headline-md": ["Montserrat"],
                            "headline-lg-mobile": ["Montserrat"],
                            "body-lg": ["Inter"],
                            "label-bold": ["Inter"],
                            "display-xl": ["Montserrat"],
                            "body-md": ["Inter"]
                        },
                        "fontSize": {
                            "label-sm": ["12px", {"lineHeight": "1.2", "fontWeight": "500"}],
                            "headline-lg": ["48px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                            "headline-md": ["24px", {"lineHeight": "1.2", "fontWeight": "700"}],
                            "headline-lg-mobile": ["32px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                            "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                            "label-bold": ["14px", {"lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "700"}],
                            "display-xl": ["80px", {"lineHeight": "1.0", "letterSpacing": "-0.04em", "fontWeight": "800"}],
                            "body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}]
                        }
                    },
                },
            }
        } catch (_e) {}
    </script>

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body>
    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}

    {% # MyCoffeeCo theme JS %}
    <script src="{{ 'mycoffeeco.js' | asset_url }}" defer></script>
  </body>
</html>
