<script>
  function initWhatWeHave() {
      const section = document.getElementById('wwh-section');
      if (!section) return;

      const loadingPhase = document.getElementById('wwh-loading');
      const welcomePhase = document.getElementById('wwh-welcome');
      const menuPhase = document.getElementById('wwh-menu');
      const percentText = document.getElementById('wwh-percent');
      const nextBtn = document.getElementById('wwh-next-btn');

      let hasPlayed = false;

      if (nextBtn) {
          nextBtn.addEventListener('click', () => showMenu());
      }

      function showMenu() {
          welcomePhase.classList.add('wwh-hidden');
          menuPhase.classList.remove('wwh-hidden');
          section.style.minHeight = 'auto';
          section.classList.remove('bg-primary');
          section.classList.add('bg-background');
          document.querySelectorAll('.wwh-menu-card').forEach((card, i) => {
              setTimeout(() => card.classList.add('wwh-active'), i * 120);
          });
      }

      const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
              if (entry.isIntersecting && !hasPlayed) {
                  hasPlayed = true;
                  startAnimation();
                  observer.unobserve(entry.target);
              }
          });
      }, { threshold: 0.3 });

      observer.observe(section);

      function startAnimation() {
          let progress = 0;

          const loadingInterval = setInterval(() => {
              progress += 1;
              percentText.textContent = progress + '%';

              if (progress >= 100) {
                  clearInterval(loadingInterval);
                  setTimeout(() => {
                      loadingPhase.classList.add('wwh-hidden');
                      welcomePhase.classList.remove('wwh-hidden');
                      setTimeout(() => {
                          welcomePhase.querySelectorAll('.wwh-slide-left, .wwh-slide-right, .wwh-slide-up').forEach(el => {
                              el.classList.add('wwh-active');
                          });
                      }, 100);
                      setTimeout(() => showMenu(), 3500);
                  }, 400);
              }
          }, 25);
      }
  }

  document.addEventListener('DOMContentLoaded', initWhatWeHave);
  document.addEventListener('shopify:section:load', function(event) {
    if (event.target.querySelector('#wwh-section')) {
      initWhatWeHave();
    }
  });
</script>

