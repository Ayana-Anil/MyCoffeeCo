<style>
  /* ===== WHAT WE HAVE SECTION ===== */
  .wwh-container {
      position: relative;
      min-height: 50vh;
      overflow: hidden;
  }
  @media (min-width: 768px) {
      .wwh-container {
          min-height: 60vh;
      }
  }
  .wwh-phase {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      opacity: 1;
      transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1);
      pointer-events: auto;
  }
  .wwh-phase.wwh-hidden {
      opacity: 0;
      pointer-events: none;
  }
  .wwh-progress-ring {
      transform: rotate(-90deg);
      transform-origin: center;
  }
  @keyframes wwh-stir {
      0% { transform: rotate(0deg); transform-origin: 100px 120px; }
      50% { transform: rotate(15deg); transform-origin: 100px 120px; }
      100% { transform: rotate(0deg); transform-origin: 100px 120px; }
  }
  .wwh-stir-arm {
      animation: wwh-stir 1.2s ease-in-out infinite;
  }
  .wwh-slide-left {
      transform: translateX(-120%);
      opacity: 0;
      transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.8s ease;
  }
  .wwh-slide-left.wwh-active {
      transform: translateX(0);
      opacity: 1;
  }
  .wwh-slide-right {
      transform: translateX(120%);
      opacity: 0;
      transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.8s ease;
  }
  .wwh-slide-right.wwh-active {
      transform: translateX(0);
      opacity: 1;
  }
  .wwh-slide-up {
      transform: translateY(60px);
      opacity: 0;
      transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.6s ease;
  }
  .wwh-slide-up.wwh-active {
      transform: translateY(0);
      opacity: 1;
  }
  .wwh-menu-card {
      transform: translateY(30px);
      opacity: 0;
      transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.5s ease;
      border: 2px solid #e2e2e2;
  }
  .wwh-menu-card.wwh-active {
      transform: translateY(0);
      opacity: 1;
  }
  .wwh-menu-card:hover {
      border-color: var(--color-primary, #0300be);
      box-shadow: 0 8px 24px rgba(3, 0, 190, 0.12);
  }
  @keyframes wwh-float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-8px); }
  }
  .wwh-float {
      animation: wwh-float 3s ease-in-out infinite;
  }
</style>

